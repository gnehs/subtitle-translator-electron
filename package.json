{
  "name": "subtitle-translator-electron",
  "version": "2.0.2",
  "main": "dist-electron/main/index.js",
  "description": "Translate subtitle using ChatGPT",
  "author": "gnehs",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run check && vite build && electron-builder --publish never",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/analysis-output.test.mts tests/api-host.test.mts tests/locale.test.mts tests/path-claims.test.mts tests/request-rate-limiter.test.mts tests/retry-after.test.mts tests/subtitle-chunks.test.mts tests/subtitle-preview.test.mts tests/subtitle-sampling.test.mts tests/translation-checkpoint.test.mts tests/translation-output.test.mts tests/version.test.mts",
    "check": "pnpm run typecheck && pnpm run test",
    "preview": "vite preview",
    "pree2e": "vite build --mode=test",
    "e2e": "playwright test",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^6.5.0",
    "@lingui/cli": "^6.5.0",
    "@lingui/vite-plugin": "^6.5.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/tiny-async-pool": "^2.0.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-electron-plugin": "^0.8.3"
  },
  "engines": {
    "node": ">=24.17.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.7",
    "@fontsource-variable/geist": "^5.2.9",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@reduxjs/toolkit": "^2.12.0",
    "ai": "^7.0.22",
    "ass-parser": "^0.2.0",
    "ass-stringify": "^0.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "subtitle": "^4.2.2",
    "tailwind-merge": "^3.6.0",
    "tiny-async-pool": "^2.1.0",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.4.3"
  }
}
